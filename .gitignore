# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage
*.lcov

# nyc test coverage
.nyc_output

# Grunt intermediate storage (https://gruntjs.com/creating-plugins#storing-shared-files)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-waf and ojc compiles
node_modules/
jspm_packages/

# Snowpack dependency directory (https://snowpack.dev/)
web_modules/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Microbundle cache
.rts2_cache_main
.rts2_cache_lit
.rts2_cache_cjs
.rts2_cache_es
.rts2_cache_umd

# REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variable files
.env
.env.development.local
.env.test.local
.env.production.local
.env.local

# parcel-cache
.cache
.parcel-cache

# Next.js build images
.next
out

# Nuxt.js build and generate files
.nuxt
dist

# Gatsby files
.cache/
# Comment in the public line if your project uses Gatsby and you want to ensure the public folder isn't committed
# public

# vuepress build output
.vuepress/dist

# Serverless Webpack directories
.webpack/

# Service Answer/Serverless directories
.serverless/

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/

# Tern JS port file
.tern-port

# Stores VS Code state in a git repository
.vscode/
#   except for extensions.json and launch.json
!.vscode/extensions.json
!.vscode/launch.json
.idea/

# Playwright files
test-results/
playwright-report/
blob-report/
playwright/.local-browsers/

# k6 files (if any temporary results or binaries)
k6-bin/

# OS files
.DS_Store
Thumbs.db
